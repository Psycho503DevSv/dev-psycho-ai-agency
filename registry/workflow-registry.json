{
  "workflows": [
    {
      "id": "wf-discovery",
      "name": "Project Discovery",
      "trigger": "User request for new app/feature",
      "steps": ["orchestrator", "knowledge-manager"],
      "output_file": "docs/requirements.md"
    },
    {
      "id": "wf-planning",
      "name": "Project Planning",
      "trigger": "Requirements approved",
      "steps": ["orchestrator", "project-manager"],
      "output_file": "docs/architecture.md"
    },
    {
      "id": "wf-implementation",
      "name": "Project Implementation",
      "trigger": "Roadmap ready",
      "steps": ["orchestrator", "ai-engineer"],
      "output_file": "src/*"
    },
    {
      "id": "wf-review",
      "name": "Project Review",
      "trigger": "Task complete",
      "steps": ["orchestrator", "ai-engineer"],
      "output_file": "docs/qa-report.md"
    },
    {
      "id": "wf-maintenance",
      "name": "Project Maintenance",
      "trigger": "Bug report",
      "steps": ["orchestrator", "ai-engineer", "knowledge-manager"],
      "output_file": "docs/maintenance-log.md"
    },
    {
      "id": "wf-build-project",
      "name": "Build Full Project",
      "trigger": "User spec for new tool",
      "steps": ["orchestrator", "project-manager", "ai-engineer", "knowledge-manager"],
      "output_file": "projects/{project_name}/*"
    }
  ]
}
